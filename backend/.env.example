# ========================================
# CONFIGURAÇÃO DO SERVIDOR
# ========================================
PORT=4000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

# ========================================
# BANCO DE DADOS - PostgreSQL
# ========================================
DATABASE_URL=postgresql://usuario:senha@localhost:5432/midia_igreja
# Ou variáveis separadas:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=usuario
# DB_PASSWORD=senha
# DB_NAME=midia_igreja

# ========================================
# AUTENTICAÇÃO - JWT
# ========================================
JWT_SECRET=sua_chave_secreta_super_segura_aqui
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=outra_chave_secreta_para_refresh
JWT_REFRESH_EXPIRES_IN=30d

# ========================================
# GOOGLE CALENDAR API
# ========================================
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
GOOGLE_CALENDAR_ID=primary

# ========================================
# CLOUDINARY (Storage de Mídia)
# ========================================
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret

# ========================================
# EVOLUTION API (WhatsApp)
# ========================================
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_api_key
EVOLUTION_INSTANCE_NAME=midia_igreja

# ========================================
# SESSION (para OAuth)
# ========================================
SESSION_SECRET=session_secret_key
